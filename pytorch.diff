# PyTorch + torch_npu 修改补丁
# 用于支持 FlexAttention 在 Ascend NPU 上的 Inductor lowering 路径
#
# 注意: 这些修改直接应用于 site-packages 中的已安装包
# 备份文件: *.bak

diff --git a/torch/nn/attention/flex_attention.py b/torch/nn/attention/flex_attention.py
--- a/torch/nn/attention/flex_attention.py
+++ b/torch/nn/attention/flex_attention.py
@@ -1363,7 +1363,7 @@
-    supported_devices = {"cuda", "cpu", "xpu", "hpu"}
+    supported_devices = {"cuda", "cpu", "xpu", "hpu", "npu"}
@@ -1366,1 +1366,1 @@
-            "FlexAttention is only supported on CUDA, CPU or HPU devices. "
+            "FlexAttention is only supported on CUDA, CPU, HPU or NPU devices. "

diff --git a/torch/_inductor/kernel/flex/flex_attention.py b/torch/_inductor/kernel/flex/flex_attention.py
--- a/torch/_inductor/kernel/flex/flex_attention.py
+++ b/torch/_inductor/kernel/flex/flex_attention.py
@@ -54,13 +54,18 @@
-    if (
-        (
-            torch.backends.cuda.matmul.fp32_precision == "ieee"
-            if torch.backends.cuda.matmul.fp32_precision != "none"
-            else torch.get_float32_matmul_precision() == "highest"
-        )
-        or torch.version.hip
-        or torch.mtia.is_available()
-    ):
-        return "'ieee'"
-    else:
-        return "'tf32'"
+    try:
+        if (
+            (
+                torch.backends.cuda.matmul.fp32_precision == "ieee"
+                if torch.backends.cuda.matmul.fp32_precision != "none"
+                else torch.get_float32_matmul_precision() == "highest"
+            )
+            or torch.version.hip
+            or (hasattr(torch, "mtia") and torch.mtia.is_available())
+        ):
+            return "'ieee'"
+        else:
+            return "'tf32'"
+    except (AttributeError, RuntimeError, AssertionError):
+        return "'ieee'"

diff --git a/torch/_inductor/kernel/flex/flex_decoding.py b/torch/_inductor/kernel/flex/flex_decoding.py
--- a/torch/_inductor/kernel/flex/flex_decoding.py
+++ b/torch/_inductor/kernel/flex/flex_decoding.py
@@ -105,8 +105,12 @@
-    if torch.xpu.is_available():
+    if hasattr(torch, "xpu") and torch.xpu.is_available():
         num_SM = torch.xpu.get_device_properties("xpu").gpu_subslice_count
-    else:
+    elif hasattr(torch, "npu") and torch.npu.is_available():
+        num_SM = 48  # Ascend 910B3 has 48 AI Cores
+    elif torch.cuda.is_available():
         num_SM = torch.cuda.get_device_properties("cuda").multi_processor_count
+    else:
+        num_SM = 48  # fallback

diff --git a/torch_npu/_inductor/lowering_op_list.py b/torch_npu/_inductor/lowering_op_list.py
--- a/torch_npu/_inductor/lowering_op_list.py
+++ b/torch_npu/_inductor/lowering_op_list.py
@@ -84,3 +84,6 @@
 GENERATE_LIST2 = [
-    "foreach"
+    "foreach",
+    "flex_attention",
+    "flex_attention_backward",
+    "zeros_and_scatter",
 ]

diff --git a/torch_npu/_inductor/codegen/scheduling.py b/torch_npu/_inductor/codegen/scheduling.py
--- a/torch_npu/_inductor/codegen/scheduling.py
+++ b/torch_npu/_inductor/codegen/scheduling.py
@@ -195,1 +195,1 @@
-    def define_kernel(self, src_code, node_schedule, kernel, traced_graph_hash: str):
+    def define_kernel(self, src_code, node_schedule, kernel, traced_graph_hash: str = ""):


# ============ 修改说明 ============
#
# 1. torch/nn/attention/flex_attention.py (_validate_device)
#    - 将 "npu" 添加到 supported_devices 集合
#    - 允许 flex_attention 接受 NPU 设备的输入张量
#
# 2. torch/_inductor/kernel/flex/flex_attention.py (get_float32_precision)
#    - 添加 try/except 保护 (AttributeError, RuntimeError, AssertionError)
#    - NPU 上 torch.backends.cuda 和 torch.mtia 不可用, 会抛异常
#    - 异常时安全降级为 'ieee' 精度
#
# 3. torch/_inductor/kernel/flex/flex_decoding.py (get_split_k)
#    - 添加 NPU 分支: torch.npu.is_available() → num_SM = 48
#    - 添加 hasattr 保护: torch.xpu 在 NPU 环境可能不存在
#    - 添加 torch.cuda.is_available() 检查避免 AssertionError
#
# 4. torch_npu/_inductor/lowering_op_list.py (GENERATE_LIST2)
#    - 添加 "flex_attention", "flex_attention_backward", "zeros_and_scatter"
#    - 防止 torch_npu 的 _register_npu_inductor_fallbacks() 将这些 HOP
#      强制 fallback, 覆盖专用 Triton 模板 lowering
#
# 5. torch_npu/_inductor/codegen/scheduling.py (define_kernel)
#    - 将 traced_graph_hash 参数改为可选 (default="")
#    - 修复 torch_npu 重写的方法签名与基类调用不匹配的问题
